# Copy this file to .env and adjust as needed.
# When running via `docker compose up`, these are already set in docker-compose.yml
# for the app container — this file is mainly for running `npm run dev` locally
# against the dockerized Postgres.

DATABASE_URL="postgresql://pos_user:pos_password@localhost:5432/pos_db?schema=public"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-a-long-random-string"
